# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# --- Auth (API login & JWT signing) ---
ADMIN_USER=admin
ADMIN_PWD=your-secure-password
JWT_SECRET=change-me-to-a-long-random-string

# --- Database ---
MONITOR_DB_DIR=data
MONITOR_DB_NAME=dvt_monitor_results.db

# --- Device config file ---
MONITOR_DEVICES_FILE=devices.json

# --- Optional ---
# TOKEN_EXPIRE_MINUTES=60
